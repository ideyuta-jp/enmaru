# Application — Prisma connection string.
# For host dev (pnpm dev) the DB is reachable at localhost; inside Docker it is "db".
DATABASE_URL="mysql://app:app@localhost:3306/webapp"

# MySQL — consumed by the "db" service in docker-compose.yml.
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=webapp
MYSQL_USER=app
MYSQL_PASSWORD=app

# E2E (Playwright) — base URL of the app under test.
E2E_BASE_URL=http://localhost:3000
