# Database — Neon (serverless PostgreSQL) connection string.
# Use the *pooled* endpoint (host contains "-pooler") for serverless/Vercel.
# Local dev points at a dev Neon branch; production is set in Vercel env vars.
DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Storage — Cloudflare R2 (S3-compatible). Local dev uses a dev bucket;
# production is set in Vercel env vars.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-dev-bucket-name"

# E2E (Playwright) — base URL of the app under test.
E2E_BASE_URL=http://localhost:3000
