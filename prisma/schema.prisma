// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Database is Neon (serverless PostgreSQL). The connection string is supplied
// at runtime via the driver adapter (see src/lib/prisma.ts) and to the Prisma
// CLI via prisma.config.ts (DATABASE_URL).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// The data model for the MVP. Shapes follow docs/requirements.md (the What);
// see docs/design.md for where the code that uses these models lives. Naming:
// PascalCase models, camelCase fields, cuid() ids.
//
// Core shape of the flow:
//   JobPosting (1) в”Җв”Җ< Engagement (N)   вҖ” one posting, many seekers (future)
// A JobPosting is a nursery's offer. An Engagement is one seeker's whole
// involvement with that posting: it is created when the seeker applies (matching
// is immediate), then runs MATCHED -> WORKING -> COMPLETED and carries the mutual
// review. "Applying" is the birth of an Engagement, not a separate entity. The
// posting's own open/closed life is JobPosting.status, kept apart from each
// seeker's lifecycle.
//
// Vocabulary вҖ” "Job" vs "Work" are used deliberately, not interchangeably:
//   - Job / JobPosting: the posting (the offer a nursery lists). JobStatus is the
//     posting's open/closed state.
//   - Work: the actual shift the posting offers. workContent / workDate /
//     workTime* describe that shift; WorkReport confirms it was performed.
// In short: a JobPosting advertises Work.
//
// Public/private boundary is NOT expressed by field-level flags here. What a
// non-admin sees is defined structurally by the DTOs in src/types/
// (PublicSeeker / PublicNursery) and enforced in server/ вҖ” see docs/requirements.md.

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SEEKER
  NURSERY
  ADMIN
}

enum JobStatus {
  OPEN
  CLOSED
}

// Lifecycle of one Engagement. Matching is immediate and first-come, so an
// Engagement is born at MATCHED. Review progress is tracked separately (see
// ReviewStatus), not as extra states here.
enum EngagementStatus {
  MATCHED
  WORKING
  COMPLETED
}

// How far the mutual review has progressed for a completed Engagement.
enum ReviewStatus {
  NONE
  PARTIAL
  DONE
}

// The two parties to an Engagement. Deliberately separate from Role: a Role can
// be ADMIN, but only a seeker or a nursery can be a party to an Engagement.
// Using Party for things like WorkReport.reporter makes "admin filed a report"
// unrepresentable rather than something to validate against at runtime.
enum Party {
  SEEKER
  NURSERY
}

// Kinds of document a seeker submits for admin verification (the application
// gate). Scoped to the seeker so future nursery-side documents (audit, billing)
// get their own type rather than overloading this one.
enum SeekerDocumentType {
  RESUME // еұҘжӯҙжӣёзӣёеҪ“жғ…е ұ
  LICENSE // дҝқиӮІеЈ«иЁј
  HEALTH_CHECK // еҒҘеә·иЁәж–ӯжӣё
  STOOL_TEST // жӨңдҫҝзөҗжһңпјҲдёҖйғЁгҒ®еӢҹйӣҶгҒ®гҒҝеҝ…й Ҳпјү
}

enum SeekerDocumentStatus {
  PENDING // зўәиӘҚдёӯ
  APPROVED // иӘҚиЁјжёҲгҒҝ
  REJECTED // е·®гҒ—жҲ»гҒ—
}

// ---------------------------------------------------------------------------
// Account
// ---------------------------------------------------------------------------

model User {
  id         String    @id @default(cuid())
  // Logto subject (OIDC `sub`). Auth lives in Logto; no password is stored here.
  // Named generically so swapping the auth provider touches lib/ + this field
  // only, not the rest of the model.
  authId     String    @unique
  email      String    @unique
  role       Role
  isActive   Boolean   @default(true)
  // Terms agreement (required for seeker and nursery at registration).
  agreedAt   DateTime?
  // LINE Messaging API user id, obtained from the required friend-add at
  // registration. Null until the friend-add completes.
  lineUserId String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  seekerProfile  SeekerProfile?
  nurseryProfile NurseryProfile?
  notifications  Notification[]
  chatMessages   ChatMessage[]
}

model SeekerProfile {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id])
  realName    String
  displayName String

  // еёҢжңӣгӮЁгғӘгӮўпјҲе…¬й–Ӣпјү
  preferredPrefecture String?
  preferredCity       String?

  // иіҮж јгғ»зөҢйЁ“пјҲе…¬й–Ӣпјү
  licenses        String[] @default([])
  experienceYears String?

  // гғ–гғ©гғігӮҜжңҹй–“пјҲгғһгғғгғҒгғігӮ°зӣёжүӢгҒ®гҒҝпјү
  blankYears String?

  // еҫ—ж„ҸеҲҶйҮҺпјҲе…¬й–Ӣпјү
  skills     String[] @default([])
  skillsNote String?

  // иҒ·еӢҷзөҢжӯҙпјҲгғһгғғгғҒгғігӮ°зӣёжүӢгҒ®гҒҝпјү
  experience String?

  // еёҢжңӣеӢӨеӢҷгӮ№гӮҝгӮӨгғ«пјҲе…¬й–Ӣпјү
  preferredPeriod   String[] @default([])
  preferredTimeSlot String[] @default([])

  // й–ўгӮҸгӮҠгҒҹгҒ„е№ҙйҪўеұӨпјҲе…¬й–ӢпјүгҖӮйҒёжҠһиӮўгғҶгӮӯгӮ№гғҲгҒҜгӮўгғ—гғӘеұӨпјҲгӮігғігғқгғјгғҚгғігғҲпјүгҒ§з®ЎзҗҶгҒҷгӮӢгҖӮ
  preferredAgeGroups String[] @default([])

  // еӨ§еҲҮгҒ«гҒ—гҒҰгҒ„гӮӢгҒ“гҒЁпјҲе…¬й–Ӣпјү
  values String?

  // иҮӘе·ұзҙ№д»ӢпјҲе…¬й–Ӣпјү
  bio String?

  // ең’гҒ®ж–№гҒёгҒІгҒЁгҒ“гҒЁпјҲе…¬й–Ӣпјү
  messageToNursery String?

  // NGгҒӘжқЎд»¶пјҲйқһе…¬й–Ӣпјү
  ngConditions     String[] @default([])
  ngConditionsNote String?

  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  engagements Engagement[]
  documents   SeekerDocument[]
  resume      SeekerResume?
}

// дҝқиӮІеЈ«гғҗгғҮгӮЈгҒҢWebдёҠгҒ§е…ҘеҠӣгҒҷгӮӢеұҘжӯҙжӣёгҒ®еҶ…е®№ вҖ” SeekerDocument(RESUME)гҒЁгҒ—гҒҰ
// иҮӘеӢ•дҝқеӯҳгҒ•гӮҢгӮӢPDFгҒ®е…ғгғҮгғјгӮҝгҖӮSeekerProfileгҒЁ1еҜҫ1гҖӮгҒ“гҒ“гҒ«жҢҒгҒҹгҒӣгӮӢй …зӣ®гҒҜ
// SeekerProfileгҒҢзҸҫзҠ¶жҢҒгҒЈгҒҰгҒ„гҒӘгҒ„PIIпјҲз®ЎзҗҶиҖ…гҒ®гҒҝй–ІиҰ§гҖҒdocs/requirements.md
// гҒ®еҖӢдәәжғ…е ұеўғз•ҢгҒ«жә–жӢ пјүгҒ®гҒҹгӮҒгҖҒSeekerProfileгӮ’зӣҙжҺҘжӢЎејөгҒӣгҒҡеҲҘгғўгғҮгғ«гҒЁгҒҷгӮӢгҖӮ
// licensesпјҲиіҮж јпјүгғ»bioпјҲиҮӘе·ұPRпјүгҒҜгҒ“гҒ“гҒ«йҮҚиӨҮгҒ•гҒӣгҒӘгҒ„ вҖ” PDFз”ҹжҲҗжҷӮгҒ«
// SeekerProfileгҒӢгӮүзӣҙжҺҘиӘӯгҒҝеҸ–гӮӢгҒ“гҒЁгҒ§гҖҒжғ…е ұжәҗгӮ’дёҖжң¬еҢ–гҒҷгӮӢгҖӮ
model SeekerResume {
  id       String        @id @default(cuid())
  seekerId String        @unique
  seeker   SeekerProfile @relation(fields: [seekerId], references: [id])

  // з”ҹе№ҙжңҲж—Ҙгғ»дҪҸжүҖгғ»йӣ»и©ұз•ӘеҸ·пјҲз®ЎзҗҶиҖ…гҒ®гҒҝпјү
  birthDate   DateTime?
  postalCode  String?
  prefecture  String?
  city        String?
  addressLine String?
  phone       String?
  // иЁјжҳҺеҶҷзңҹпјҲR2гӮӘгғ–гӮёгӮ§гӮҜгғҲгӮӯгғјпјүгҖӮгӮўгғғгғ—гғӯгғјгғүUIгҒҜд»ҠеӣһжңӘе®ҹиЈ…гҖҒе°ҶжқҘиҝҪеҠ з”ЁпјҲ#167пјүгҖӮ
  photoFileKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  education   SeekerEducationHistory[]
  workHistory SeekerWorkHistory[]
}

// еӯҰжӯҙгҒ®1гӮЁгғігғҲгғӘпјҲеӯҰж ЎгҒ”гҒЁгҒ«1иЎҢпјүгҖӮPDFеҮәеҠӣжҷӮгҒ«гҖҢе…ҘеӯҰпјҸеҚ’жҘӯгҖҚгҒ®2иЎҢгҒ«еұ•й–ӢгҒҷгӮӢгҖӮ
// orderгҒ§иЎЁзӨәй ҶпјҲеҸӨгҒ„й ҶпјүгӮ’еҲ¶еҫЎгҒҷгӮӢгҖӮgraduationStatusгҒҜгғ•гӮ©гғјгғ дёҠгҒҜгғ—гғ«гғҖгӮҰгғі
// пјҲеҚ’жҘӯпјҸдёӯйҖҖпјҸеҚ’жҘӯиҰӢиҫјгҒҝпјүгҒ§йҒёгҒ°гҒӣгӮӢгҒҢгҖҒSeekerProfileгҒ®experienceYears/
// blankYearsгҒЁеҗҢгҒҳгҖҢгӮ№гӮӯгғјгғһгҒҜString?гҖҒйҒёжҠһиӮўгҒҜгғ•гӮ©гғјгғ еҒҙгҒ®е®ҡж•°гҖҚгҒЁгҒ„гҒҶ
// ж—ўеӯҳгғ‘гӮҝгғјгғігҒ«еҖЈгҒ„гҖҒPrisma enumгҒ«гҒҜгҒ—гҒӘгҒ„гҖӮ
model SeekerEducationHistory {
  id               String       @id @default(cuid())
  resumeId         String
  resume           SeekerResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  schoolName       String
  graduationStatus String? // гғ•гӮ©гғјгғ дёҠгҒҜгғ—гғ«гғҖгӮҰгғіпјҡеҚ’жҘӯпјҸдёӯйҖҖпјҸеҚ’жҘӯиҰӢиҫјгҒҝ
  // 'YYYY-MM'еҪўејҸгҖӮеұҘжӯҙжӣёгҒ®ж…ЈдҫӢгҒ«еҗҲгӮҸгҒӣж—Ҙд»ҳзІҫеәҰгҒҜжңҲгҒҫгҒ§гҒЁгҒҷгӮӢгҖӮ
  // гғ•гӮ©гғјгғ дёҠгҒҜе№ҙгғ»жңҲгҒқгӮҢгҒһгӮҢзӢ¬з«ӢгҒ—гҒҹгғ—гғ«гғҖгӮҰгғі(Select)2гҒӨгҒ§е…ҘеҠӣгҒҷгӮӢгҖӮ
  startYearMonth String?
  endYearMonth   String? // з©әж¬„=еңЁеӯҰдёӯ
  order          Int      @default(0)
}

// иҒ·жӯҙгҒ®1гӮЁгғігғҲгғӘпјҲдјҒжҘӯгҒ”гҒЁгҒ«1иЎҢпјүгҖӮSeekerProfile.experienceпјҲгғһгғғгғҒгғігӮ°
// зӣёжүӢеҗ‘гҒ‘гҒ®иҮӘз”ұиЁҳиҝ°гҒ®иҒ·еӢҷзөҢжӯҙпјүгҒЁгҒҜеҲҘзү© вҖ” гҒ“гҒЎгӮүгҒҜеұҘжӯҙжӣёе°Ӯз”ЁгҒ®ж§ӢйҖ еҢ–гғҮгғјгӮҝгҖӮ
// employmentTypeгӮӮgraduationStatusгҒЁеҗҢж§ҳгҖҒгӮ№гӮӯгғјгғһгҒҜString?гғ»гғ•гӮ©гғјгғ еҒҙгҒ§
// гғ—гғ«гғҖгӮҰгғігҒ®йҒёжҠһиӮўгӮ’жҢҒгҒӨгҖӮ
model SeekerWorkHistory {
  id             String       @id @default(cuid())
  resumeId       String
  resume         SeekerResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  companyName    String
  employmentType String? // гғ•гӮ©гғјгғ дёҠгҒҜгғ—гғ«гғҖгӮҰгғіпјҡжӯЈзӨҫе“ЎпјҸеҘ‘зҙ„зӨҫе“ЎпјҸжҙҫйҒЈзӨҫе“ЎпјҸгғ‘гғјгғҲгғ»гӮўгғ«гғҗгӮӨгғҲпјҸжҘӯеӢҷе§”иЁ—пјҸгҒқгҒ®д»–
  description    String? // жҘӯеӢҷеҶ…е®№гҒӘгҒ©иҮӘз”ұиЁҳиҝ°пјҲд»»ж„Ҹпјү
  startYearMonth String?
  endYearMonth   String? // з©әж¬„=зҸҫеңЁеӢӨеӢҷдёӯ
  order          Int      @default(0)
}

model NurseryProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // еҹәжң¬жғ…е ұпјҲе…¬й–Ӣпјү
  nurseryName String
  postalCode  String?
  prefecture  String?
  city        String?
  addressLine String?
  phone       String?
  contactName String

  // SNSгғ»URLпјҲе…¬й–Ӣпјү
  homepageUrl  String?
  instagramUrl String?
  twitterUrl   String?
  facebookUrl  String?
  otherSnsUrl  String?

  // ең’гҒ®зү№еҫҙпјҲе…¬й–Ӣпјү
  featureTags String[]
  featureNote String?

  // еҸ—гҒ‘е…ҘгӮҢж–№йҮқпјҲе…¬й–Ӣпјү
  receptionTags String[]
  receptionNote String?

  // ең’гҒӢгӮүгҒ®гғЎгғғгӮ»гғјгӮёпјҲе…¬й–Ӣпјү
  joinReason      String?
  idealPartner    String?
  additionalNotes String?

  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Engagements and reviews are reached through jobPostings, not stored here:
  // an Engagement keeps only jobId + seekerId (the nursery is derived via the
  // posting), so there is no redundant nurseryId to keep in sync.
  jobPostings JobPosting[]
  photos      NurseryPhoto[]
}

model NurseryPhoto {
  id         String         @id @default(cuid())
  nurseryId  String
  nursery    NurseryProfile @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  fileKey    String
  isMain     Boolean        @default(false)
  order      Int            @default(0)
  uploadedAt DateTime       @default(now())
}

// ---------------------------------------------------------------------------
// Posting and engagement
// ---------------------------------------------------------------------------

model JobPosting {
  id                        String               @id @default(cuid())
  nurseryId                 String
  nursery                   NurseryProfile       @relation(fields: [nurseryId], references: [id])
  title                     String
  // Work content is a tag selection plus a free note, stored separately вҖ”
  // packing both into one delimited string lets free text collide with the
  // tag delimiter (same tags+note shape as SeekerProfile.skills/skillsNote).
  // At least one of the two is required (enforced in server/job-actions.ts).
  workContentTags           String[]             @default([])
  workContentNote           String?
  workDate                  DateTime
  workTimeStart             String // 'HH:mm'
  workTimeEnd               String // 'HH:mm'
  hourlyWage                Int? // null = undecided
  // Same tags+note split as workContent above (both parts optional here).
  targetPersonTags          String[]             @default([])
  targetPersonNote          String?
  remarks                   String?
  // Documents this posting requires to be verified before a seeker may apply.
  requiredDocuments         SeekerDocumentType[] @default([])
  // дәӨйҖҡиІ»: true=гҒӮгӮҠ / false=гҒӘгҒ— / null=жңӘиЁӯе®ҡ
  transportationExpense     Boolean?
  transportationExpenseNote String?
  // еӢӨеӢҷжҷӮгҒ®жңҚиЈ…
  dresscode                 String?
  status                    JobStatus            @default(OPEN)
  postedAt                  DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  engagements Engagement[]
}

// One seeker's whole involvement with one posting, from applying through the
// mutual review. Created when the seeker applies (immediate, first-come match),
// so applyMessage/lineContactOk live here and createdAt is the application time.
// Holds only jobId + seekerId; the nursery is reached via job.
model Engagement {
  id            String           @id @default(cuid())
  jobId         String
  job           JobPosting       @relation(fields: [jobId], references: [id])
  seekerId      String
  seeker        SeekerProfile    @relation(fields: [seekerId], references: [id])
  applyMessage  String?
  lineContactOk Boolean          @default(false)
  status        EngagementStatus @default(MATCHED)
  completedAt   DateTime?
  reviewStatus  ReviewStatus     @default(NONE)
  // Admin-only operating note.
  adminMemo     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  workReports           WorkReport[]
  chatMessages          ChatMessage[]
  reviewNurseryToSeeker ReviewNurseryToSeeker?
  reviewSeekerToNursery ReviewSeekerToNursery?

  // A seeker can engage a given posting only once.
  @@unique([jobId, seekerId])
}

// Both parties confirm the shift happened; the Engagement becomes COMPLETED once
// both reports are in. (Whether the nursery must also report is an open question
// in docs/requirements.md вҖ” current behavior follows the spec: both report.)
model WorkReport {
  id           String     @id @default(cuid())
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  reporter     Party
  completed    Boolean
  comment      String?
  reportedAt   DateTime   @default(now())

  // Each party reports at most once per engagement.
  @@unique([engagementId, reporter])
}

// ---------------------------------------------------------------------------
// Chat, documents, notifications
// ---------------------------------------------------------------------------

// A chat message within an engagement. Named specifically (not "Message") to
// leave room for other message kinds the app may grow. Chat is available from
// when the engagement forms until 24h after completion; that time-window rule is
// enforced in server/, not the schema.
model ChatMessage {
  id           String     @id @default(cuid())
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  senderId     String
  sender       User       @relation(fields: [senderId], references: [id])
  body         String
  createdAt    DateTime   @default(now())
}

// A document a seeker submits for verification. Named SeekerDocument (not
// "Document") because the app will likely handle other document kinds later
// (nursery audit paperwork, billing), which should be their own models.
// fileKey is the R2 object key (a signed URL is produced via src/lib/storage.ts).
// RESUME's file can come from either a manual upload (document-actions.ts's
// uploadDocument) or an auto-generated PDF from the seeker's web rГ©sumГ©
// (resume-actions.ts's saveResume, backed by SeekerResume) вҖ” both write to
// this same row via the same upsert key, so whichever the seeker used most
// recently wins. Admin verifies each by eye вҖ” no auto-verification.
model SeekerDocument {
  id              String               @id @default(cuid())
  seekerId        String
  seeker          SeekerProfile        @relation(fields: [seekerId], references: [id])
  documentType    SeekerDocumentType
  fileKey         String
  status          SeekerDocumentStatus @default(PENDING)
  rejectionReason String?
  uploadedAt      DateTime             @default(now())
  verifiedAt      DateTime?

  // One current document per type per seeker.
  @@unique([seekerId, documentType])
}

// In-app notification. `type` is a string rather than an enum so new kinds do
// not each require a migration; the known values are a union in the TS layer.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Mutual review (one row per direction per engagement; both gated on COMPLETED).
// Linked only to the engagement; seeker/nursery are derived via it.
// isPublished is false by default: reviews start private until admin publishes.
// ---------------------------------------------------------------------------

model ReviewNurseryToSeeker {
  id            String     @id @default(cuid())
  engagementId  String     @unique
  engagement    Engagement @relation(fields: [engagementId], references: [id])
  attitude      Int // еӢӨеӢҷж…ӢеәҰ 1-5
  communication Int // гӮігғҹгғҘгғӢгӮұгғјгӮ·гғ§гғі 1-5
  skill         Int // жҘӯеӢҷгҒёгҒ®е§ҝеӢў 1-5
  comment       String?
  wouldRehire   Boolean
  isPublished   Boolean    @default(false)
  reviewedAt    DateTime   @default(now())
}

model ReviewSeekerToNursery {
  id             String     @id @default(cuid())
  engagementId   String     @unique
  engagement     Engagement @relation(fields: [engagementId], references: [id])
  explanation    Int // еҸ—гҒ‘е…ҘгӮҢиӘ¬жҳҺгҒ®дёҒеҜ§гҒ• 1-5
  atmosphere     Int // зҸҫе ҙгҒ®йӣ°еӣІж°— 1-5
  support        Int // гӮөгғқгғјгғҲдҪ“еҲ¶ 1-5
  clarity        Int // жҘӯеӢҷеҶ…е®№гҒ®жҳҺзўәгҒ• 1-5
  comment        String?
  wouldWorkAgain Boolean
  isPublished    Boolean    @default(false)
